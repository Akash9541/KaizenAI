generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Primary connection URL.
  // For pooled providers (Neon, Supabase): use the POOLED connection URL here.
  url       = env("DATABASE_URL")
  // Direct (non-pooled) URL — used by Prisma CLI for migrations and introspection.
  // For Neon: remove "-pooler" from the hostname.
  // For non-pooled providers (Railway, local): same as DATABASE_URL.
  directUrl = env("DIRECT_URL")
  // shadowDatabaseUrl is intentionally omitted here.
  // Prisma only needs it for `prisma migrate dev` (local dev workflow).
  // If your DB user has CREATE privileges, Prisma creates the shadow DB automatically.
  // If not (e.g., Neon free tier), set SHADOW_DATABASE_URL and add:
  //   shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                      String           @id @default(uuid())
  clerkUserId             String?          @unique
  email                   String           @unique
  name                    String?
  imageUrl                String?
  industry                String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  bio                     String?
  experience              Int?
  skills                  String[]
  
  // Authentication fields
  passwordHash            String?
  // Temporarily holds the hashed password during sign-up until OTP is verified.
  // On successful OTP verification, this is committed to `passwordHash` and cleared.
  // This ensures credentials are never persisted for unverified accounts.
  pendingPasswordHash     String?
  emailVerified           Boolean          @default(false)
  emailVerificationExpiry DateTime?
  emailVerificationToken  String?          @unique
  
  // Security audit fields
  lastLoginAt             DateTime?
  lastPasswordChangeAt    DateTime?
  failedLoginAttempts     Int              @default(0)
  accountLockedUntil      DateTime?
  
  // Relations
  assessments             Assessment[]
  coverLetter             CoverLetter[]
  resume                  Resume?
  industryInsight         IndustryInsight? @relation(fields: [industry], references: [industry])

  @@index([email])
  @@index([emailVerified])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  quizScore      Float
  questions      Json[]
  category       String
  improvementTip String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String
  atsScore  Float?
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IndustryInsight {
  id                String   @id @default(cuid())
  industry          String   @unique
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       String
  topSkills         String[]
  marketOutlook     String
  keyTrends         String[]
  recommendedSkills String[]
  lastUpdated       DateTime @default(now())
  nextUpdate        DateTime
  users             User[]

  @@index([industry])
}
